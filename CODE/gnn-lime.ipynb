import pandas as pd
import torch
import numpy as np
import torch.nn.functional as F
from sklearn.neighbors import NearestNeighbors
from transformers import BertTokenizer, BertModel
import torch.nn as nn
import networkx as nx
import matplotlib.pyplot as plt

!pip install torch_geometric
from torch_geometric.data import Data
from torch_geometric.nn import GCNConv

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

fake_df = pd.read_csv("Fake.csv", low_memory=False)
fake_df["label"] = 1

real_df = pd.read_csv("True.csv", low_memory=False)
real_df["label"] = 0

df = pd.concat([fake_df, real_df])
df = df.sample(frac=1, random_state=42).reset_index(drop=True)

df["text"] = df["title"] + " " + df["text"]
df = df[["text", "label"]]
df.dropna(inplace=True)

df = df[:10000]

texts = df["text"].tolist()
labels = torch.tensor(df["label"].values, dtype=torch.long)

tokenizer = BertTokenizer.from_pretrained("bert-base-uncased")
bert_model = BertModel.from_pretrained("bert-base-uncased").to(device)
bert_model.eval()

embeddings = []

print("Generating embeddings...")
batch_size = 16

for i in range(0, len(texts), batch_size):
    batch_texts = texts[i:i+batch_size]

    inputs = tokenizer(batch_texts,
                       return_tensors="pt",
                       truncation=True,
                       padding=True,
                       max_length=256).to(device)

    with torch.no_grad():
        outputs = bert_model(**inputs)

    cls_embeddings = outputs.last_hidden_state[:, 0, :].cpu().numpy()

    for emb in cls_embeddings:
        embeddings.append(emb)

embeddings = np.array(embeddings)

print("Building graph...")
k = 10
nbrs = NearestNeighbors(n_neighbors=k, metric="cosine").fit(embeddings)
distances, indices = nbrs.kneighbors(embeddings)

edges = []
for i in range(len(indices)):
    for j in indices[i]:
        if i != j:
            edges.append([i, j])

edge_index = torch.tensor(edges, dtype=torch.long).t().contiguous()

x = torch.tensor(embeddings, dtype=torch.float)
y = labels

data = Data(x=x, edge_index=edge_index, y=y).to(device)

num_nodes = data.num_nodes
indices = torch.randperm(num_nodes)

train_size = int(0.8 * num_nodes)

train_mask = torch.zeros(num_nodes, dtype=torch.bool)
test_mask = torch.zeros(num_nodes, dtype=torch.bool)

train_mask[indices[:train_size]] = True
test_mask[indices[train_size:]] = True

data.train_mask = train_mask.to(device)
data.test_mask = test_mask.to(device)

class GCN(nn.Module):
    def __init__(self):
        super(GCN, self).__init__()
        self.conv1 = GCNConv(768, 128)
        self.conv2 = GCNConv(128, 2)
        self.dropout = nn.Dropout(0.3)

    def forward(self, data):
        x, edge_index = data.x, data.edge_index
        x = self.conv1(x, edge_index)
        x = F.relu(x)
        x = self.dropout(x)
        x = self.conv2(x, edge_index)
        return x

model = GCN().to(device)
optimizer = torch.optim.Adam(model.parameters(), lr=0.001)

print("Training GNN...")
for epoch in range(130):
    model.train()
    optimizer.zero_grad()
    out = model(data)
    loss = F.cross_entropy(out[data.train_mask],
                           data.y[data.train_mask])
    loss.backward()
    optimizer.step()

    if epoch % 5 == 0:
        pred = out.argmax(dim=1)
        train_acc = (pred[data.train_mask] ==
                     data.y[data.train_mask]).sum().item() / data.train_mask.sum().item()
        print(f"Epoch {epoch}, Loss: {loss.item():.4f}, Train Acc: {train_acc:.4f}")

model.eval()
out = model(data)
pred = out.argmax(dim=1)

test_correct = (pred[data.test_mask] ==
                data.y[data.test_mask]).sum()
test_acc = int(test_correct) / int(data.test_mask.sum())

print("Final Test Accuracy:", test_acc)

sample_text = "Government confirms alien spaceship landing in Delhi."

inputs = tokenizer(sample_text,
                   return_tensors="pt",
                   truncation=True,
                   padding=True,
                   max_length=256).to(device)

with torch.no_grad():
    outputs = bert_model(**inputs)

new_embedding = outputs.last_hidden_state[:, 0, :].squeeze().cpu().numpy()

similarities = np.dot(embeddings, new_embedding)
nearest_idx = np.argmax(similarities)

print("Most similar training article label:",
      "Fake" if df.iloc[nearest_idx]["label"] == 1 else "Real")

print("Drawing graph...")

G = nx.Graph()
edges_np = edge_index.cpu().numpy()

for i in range(edges_np.shape[1]):
    G.add_edge(int(edges_np[0][i]), int(edges_np[1][i]))

subset_nodes = list(G.nodes())[:200]
subgraph = G.subgraph(subset_nodes)

node_colors = []
for node in subgraph.nodes():
    if df.iloc[node]["label"] == 1:
        node_colors.append("red")
    else:
        node_colors.append("blue")

plt.figure(figsize=(10,10))
pos = nx.spring_layout(subgraph, seed=42)

nx.draw(subgraph,
        pos,
        node_color=node_colors,
        node_size=40,
        with_labels=False)

plt.title("Fake News Graph (Red=Fake, Blue=Real)")
plt.show()


from sklearn.metrics import confusion_matrix
import seaborn as sns
import matplotlib.pyplot as plt

model.eval()

with torch.no_grad():
    out = model(data)
    pred = out.argmax(dim=1)

true_labels = data.y[data.test_mask].cpu().numpy()
predicted_labels = pred[data.test_mask].cpu().numpy()

cm = confusion_matrix(true_labels, predicted_labels)

plt.figure(figsize=(6, 5))
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
            xticklabels=['Real', 'Fake'], yticklabels=['Real', 'Fake'])
plt.xlabel('Predicted Label')
plt.ylabel('True Label')
plt.title('Confusion Matrix for Fake News Detection')
plt.show()

test_indices = torch.where(data.test_mask)[0].cpu().numpy()

false_positives_indices_relative = np.where((true_labels == 0) & (predicted_labels == 1))[0]
false_negatives_indices_relative = np.where((true_labels == 1) & (predicted_labels == 0))[0]

print(f"\nNumber of False Positives (Real news classified as Fake): {len(false_positives_indices_relative)}")
print(f"Number of False Negatives (Fake news classified as Real): {len(false_negatives_indices_relative)}")

actual_false_positives_indices = test_indices[false_positives_indices_relative]

print("\n--- Examples of Misclassified Fake News (False Positives): ---")
if len(actual_false_positives_indices) > 0:
    for i, idx in enumerate(actual_false_positives_indices[:5]):
        print(f"Example {i+1} (Original Index: {idx}):\n{df.iloc[idx]['text']}\n")
else:
    print("No false positives found.")



def predict_proba(texts):
    model.eval()
    probs_list = []

    for text in texts:
        inputs = tokenizer(text, return_tensors='pt', truncation=True, padding=True, max_length=256).to(device)

        with torch.no_grad():
            outputs = bert_model(**inputs)
            embedding = outputs.last_hidden_state[:, 0, :].cpu().numpy()

        distances, indices = nbrs.kneighbors(embedding)

        neighbor_embeddings = embeddings[indices[0]]
        all_embeddings = np.vstack([embedding, neighbor_embeddings])

        edges = []
        for i in range(len(all_embeddings)):
            for j in range(len(all_embeddings)):
                if i != j:
                    edges.append([i, j])

        edge_index = torch.tensor(edges, dtype=torch.long).t().contiguous().to(device)
        x = torch.tensor(all_embeddings, dtype=torch.float).to(device)

        data = Data(x=x, edge_index=edge_index)

        out = model(data)
        prob = torch.softmax(out, dim=1).detach().cpu().numpy()

        probs_list.append(prob[0])

    return np.array(probs_list)


